# football-data.org 免费API Key（注册：https://www.football-data.org/client/register）
FOOTBALL_DATA_API_KEY=你的Key

# Claude API Key（https://console.anthropic.com）
ANTHROPIC_API_KEY=你的Key

# Upstash Redis（Vercel连接后自动注入，本地开发填Upstash控制台的值）
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=你的Token

# Cron安全验证（随机字符串即可）
CRON_SECRET=abc123xyz
